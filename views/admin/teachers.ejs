<%- include('../partials/admin-head', { title: 'Teachers', activePage: 'teachers' }) %>

<div class="admin-page">
  <div class="admin-page__actions">
    <a href="/admin/teachers/new" class="btn btn--primary">+ New teacher</a>
  </div>

  <div class="admin-card">
    <% if(teachers.length === 0) { %>
    <p class="empty-state">No teacher profiles yet. Create a profile from a Stage 7 applicant or add one manually.</p>
    <% } else { %>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Categories</th>
          <th>Languages</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% teachers.forEach(t => { %>
        <tr>
          <td>
            <div class="teacher-row">
              <% if(t.photo_path) { %><img src="<%= t.photo_path %>" class="teacher-row__photo" alt="" /><% } %>
              <strong><%= t.name %></strong>
            </div>
          </td>
          <td>
            <% const cats = Array.isArray(t.categories) ? t.categories : (t.categories || []); %>
            <% cats.forEach(c => { %><span class="tag tag--sm"><%= c %></span><% }) %>
          </td>
          <td>
            <% const langs = Array.isArray(t.languages) ? t.languages : (t.languages || []); %>
            <%= langs.join(', ') %>
          </td>
          <td>
            <span class="status-badge <%= t.is_published ? 'status-badge--live' : 'status-badge--draft' %>">
              <%= t.is_published ? 'Published' : 'Draft' %>
            </span>
          </td>
          <td class="table-actions">
            <a href="/admin/teachers/<%= t.id %>/edit" class="table-link">Edit</a>
            <form action="/admin/teachers/<%= t.id %>/publish" method="POST" style="display:inline">
              <button class="table-link table-link--btn"><%= t.is_published ? 'Unpublish' : 'Publish' %></button>
            </form>
            <button class="table-link table-link--danger" onclick="confirmDelete('<%= t.id %>', '<%= t.name.replace(/['"]/g, '') %>')">Delete</button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<div id="deleteModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:999;align-items:center;justify-content:center;">
  <div style="background:#1C201F;border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:40px;max-width:420px;width:90%;margin:auto;">
    <h3 style="font-family:var(--font-head);font-size:18px;color:#E8EDEC;margin-bottom:12px;">Delete teacher?</h3>
    <p id="deleteModalText" style="font-size:14px;color:#7A9490;margin-bottom:8px;line-height:1.6;"></p>
    <p style="font-size:13px;color:#c0392b;margin-bottom:28px;">This will permanently delete the teacher, their availability, all bookings and reviews. This cannot be undone.</p>
    <div style="display:flex;gap:12px;">
      <form id="deleteForm" method="POST" style="flex:1">
        <button type="submit" class="btn btn--danger" style="width:100%">Yes, delete permanently</button>
      </form>
      <button onclick="document.getElementById('deleteModal').style.display='none'" class="btn btn--white" style="flex:1">Cancel</button>
    </div>
  </div>
</div>

<script>
function confirmDelete(id, name) {
  document.getElementById('deleteModalText').textContent = 'You are about to delete ' + name + '. All their data will be removed from the platform.';
  document.getElementById('deleteForm').action = '/admin/teachers/' + id + '/delete';
  document.getElementById('deleteModal').style.display = 'flex';
}
</script>

<%- include('../partials/admin-foot') %>
