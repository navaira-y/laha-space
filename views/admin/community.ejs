<%- include('../partials/admin-head', { title: 'Community Members', activePage: 'community' }) %>

<style>
  @media (max-width: 680px) {
    .community-member-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<div class="admin-page">
  <p class="admin-page__sub" style="margin-bottom:16px"><%= members.length %> member<%= members.length !== 1 ? 's' : '' %> joined</p>

  <% if (!members.length) { %>
    <div class="admin-card" style="text-align:center;padding:48px;color:#7A8C89;">No community members yet.</div>
  <% } else { %>
    <% members.forEach(m => { %>
    <div class="admin-card" style="margin-bottom:16px;">
      <div class="community-member-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px 32px;margin-bottom:20px;">
        <div>
          <div class="detail-label">Name</div>
          <div class="detail-value"><%= m.name %></div>
        </div>
        <div>
          <div class="detail-label">Email</div>
          <div class="detail-value"><%= m.email %></div>
        </div>
        <div>
          <div class="detail-label">WhatsApp</div>
          <div class="detail-value"><%= m.whatsapp %></div>
        </div>
        <div>
          <div class="detail-label">Country</div>
          <div class="detail-value"><%= m.country %></div>
        </div>
        <div>
          <div class="detail-label">Age group</div>
          <div class="detail-value"><%= m.age_group %></div>
        </div>
        <div>
          <div class="detail-label">Joined</div>
          <div class="detail-value"><%= new Date(m.created_at).toLocaleDateString('en-GB') %></div>
        </div>
      </div>
      <% if (m.why_join) { %>
      <div style="margin-bottom:12px;">
        <div class="detail-label">Looking for</div>
        <div class="detail-value" style="margin-top:4px;line-height:1.6;"><%= m.why_join %></div>
      </div>
      <% } %>
      <% if (m.can_contribute) { %>
      <div style="margin-bottom:16px;">
        <div class="detail-label">Can contribute</div>
        <div class="detail-value" style="margin-top:4px;line-height:1.6;"><%= m.can_contribute %></div>
      </div>
      <% } %>
      <% if (m.voice_note) { %>
      <div style="margin-bottom:16px;">
        <div class="detail-label" style="margin-bottom:8px;">Voice note</div>
        <audio controls style="width:100%;max-width:320px;height:36px;border-radius:8px;">
          <source src="<%= m.voice_note %>" type="audio/webm">
          Your browser does not support audio playback.
        </audio>
      </div>
      <% } %>
      <div style="border-top:1px solid #DFDFDF;padding-top:14px;display:flex;justify-content:space-between;align-items:center;">
        <% if (!m.approved) { %>
        <form action="/admin/community/<%= m.id %>/approve" method="POST" style="display:inline">
          <button type="submit" class="btn btn--primary btn--sm" onclick="return confirm('Send WhatsApp link to ' + '<%= m.name %>' + '?')">Send WhatsApp invite</button>
        </form>
        <% } else { %>
        <span style="font-size:13px;color:#2E847B;font-weight:500;">✓ Invited</span>
        <% } %>
        <button class="table-link table-link--danger" onclick="if(confirm('Delete this member permanently?')) document.getElementById('del-<%= m.id %>').submit()">Delete</button>
        <form id="del-<%= m.id %>" action="/admin/community/<%= m.id %>/delete" method="POST" style="display:none"></form>
      </div>
    </div>
    <% }) %>
  <% } %>
</div>

<%- include('../partials/admin-foot') %>
