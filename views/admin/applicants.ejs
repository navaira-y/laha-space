<%- include('../partials/admin-head', { title: 'Applicants', activePage: 'applicants' }) %>

<div class="admin-page">
  <div class="admin-page__header">
    <h1 class="admin-page__title">Applicants</h1>
  </div>

  <div class="filter-bar">
    <a href="/admin/applicants" class="filter-btn <%= !selectedStage && !selectedStatus ? 'filter-btn--active' : '' %>">All active</a>
    <% for(let i = 1; i <= 7; i++) { %>
    <a href="/admin/applicants?stage=<%= i %>" class="filter-btn <%= selectedStage == i ? 'filter-btn--active' : '' %>">Stage <%= i %></a>
    <% } %>
    <a href="/admin/applicants?status=not_proceeding" class="filter-btn <%= selectedStatus === 'not_proceeding' ? 'filter-btn--active' : '' %>">Not proceeding</a>
  </div>

  <div class="admin-card">
    <% if (applicants.length === 0) { %>
    <p class="empty-state">No applicants found.</p>
    <% } else { %>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Location</th>
          <th>Stage</th>
          <th>Applied</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% applicants.forEach(a => { %>
        <tr>
          <td><strong><%= a.name %></strong></td>
          <td><%= a.email %></td>
          <td><%= a.country_city %></td>
          <td>
            <% if(a.status === 'not_proceeding') { %>
            <span class="stage-badge stage-badge--stopped">Not proceeding</span>
            <% } else { %>
            <span class="stage-badge stage-badge--<%= a.stage %>">Stage <%= a.stage %></span>
            <% } %>
          </td>
          <td><%= new Date(a.created_at).toLocaleDateString('en-GB') %></td>
          <td>
            <a href="/admin/applicants/<%= a.id %>" class="table-link">View</a>
            <button class="table-link table-link--danger" style="margin-left:8px" onclick="confirmDeleteApplicant('<%= a.id %>', '<%= a.name.replace(/['"]/g, '') %>')">Delete</button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<div id="deleteApplicantModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:999;align-items:center;justify-content:center;">
  <div style="background:#1C201F;border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:40px;max-width:420px;width:90%;margin:auto;">
    <h3 style="font-family:var(--font-head);font-size:18px;color:#E8EDEC;margin-bottom:12px;">Delete applicant?</h3>
    <p id="deleteApplicantText" style="font-size:14px;color:#7A9490;margin-bottom:8px;line-height:1.6;"></p>
    <p style="font-size:13px;color:#c0392b;margin-bottom:28px;">This will permanently delete the applicant, all their documents and uploaded files. This cannot be undone.</p>
    <div style="display:flex;gap:12px;">
      <form id="deleteApplicantForm" method="POST" style="flex:1">
        <button type="submit" class="btn btn--danger" style="width:100%">Yes, delete permanently</button>
      </form>
      <button onclick="document.getElementById('deleteApplicantModal').style.display='none'" class="btn btn--white" style="flex:1">Cancel</button>
    </div>
  </div>
</div>

<script>
function confirmDeleteApplicant(id, name) {
  document.getElementById('deleteApplicantText').textContent = 'You are about to delete ' + name + ' and all their uploaded files.';
  document.getElementById('deleteApplicantForm').action = '/admin/applicants/' + id + '/delete';
  document.getElementById('deleteApplicantModal').style.display = 'flex';
}
</script>

<%- include('../partials/admin-foot') %>
