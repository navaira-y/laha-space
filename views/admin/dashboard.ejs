<%- include('../partials/admin-head', { title: 'Dashboard', activePage: 'dashboard' }) %>

<div class="admin-page">
  <div class="admin-page__header">
    <h1 class="admin-page__title">Dashboard</h1>
  </div>

  <div class="stats-grid">
    <div class="stat-card stat-card--1">
      <div class="stat-card__icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg></div>
      <div class="stat-card__num"><%= stats.applicants %></div>
      <div class="stat-card__label">Active Applicants</div>
    </div>
    <div class="stat-card stat-card--2">
      <div class="stat-card__icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg></div>
      <div class="stat-card__num"><%= stats.teachers %></div>
      <div class="stat-card__label">Published Teachers</div>
    </div>
    <div class="stat-card stat-card--3">
      <div class="stat-card__icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg></div>
      <div class="stat-card__num"><%= stats.bookings %></div>
      <div class="stat-card__label">Pending Bookings</div>
    </div>
    <div class="stat-card stat-card--4">
      <div class="stat-card__icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H5.17L4 17.17V4h16v12z"/></svg></div>
      <div class="stat-card__num"><%= stats.pendingReviews %></div>
      <div class="stat-card__label">Reviews to Moderate</div>
    </div>
  </div>

  <div class="admin-card">
    <div class="admin-card__header">
      <h2 class="admin-card__title">Recent Applicants</h2>
      <a href="/admin/applicants" class="btn btn--outline btn--sm">View all</a>
    </div>
    <% if (recentApplicants.length === 0) { %>
    <p class="empty-state">No applicants yet.</p>
    <% } else { %>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Stage</th>
          <th>Applied</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% recentApplicants.forEach(a => { %>
        <tr>
          <td><strong><%= a.name %></strong></td>
          <td><%= a.email %></td>
          <td><span class="stage-badge stage-badge--<%= a.stage %>">Stage <%= a.stage %> — <%= STAGES[a.stage] %></span></td>
          <td><%= new Date(a.created_at).toLocaleDateString('en-GB') %></td>
          <td><a href="/admin/applicants/<%= a.id %>" class="table-link">View</a></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<%- include('../partials/admin-foot') %>
