<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin · Laha Space</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" href="/images/favicon.png" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --teal:    #2E847B;
      --teal-dk: #1a2e2c;
      --teal-lt: #4fa8a1;
      --sand:    #C4956A;
      --bg:      #f5f7f6;
      --line:    #e0e8e6;
      --ink:     #1a2e2c;
      --ink-soft:#5a7876;
    }

    html, body { height: 100%; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      display: flex;
      min-height: 100vh;
      overflow: hidden;
    }

    /* ── Left panel ── */
    .panel-left {
      width: 46%;
      flex-shrink: 0;
      background: var(--teal-dk);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 48px 52px;
      position: relative;
      overflow: hidden;
    }

    /* Geometric SVG pattern */
    .panel-left__pattern {
      position: absolute;
      inset: 0;
      opacity: 0.06;
      pointer-events: none;
    }

    /* Decorative circle */
    .panel-left::after {
      content: '';
      position: absolute;
      bottom: -120px;
      right: -80px;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(46,132,123,0.4) 0%, transparent 70%);
      pointer-events: none;
    }

    .panel-left__logo {
      position: relative;
      z-index: 1;
    }
    .panel-left__logo img {
      height: 46px;
      width: auto;
      display: block;
      filter: brightness(0) invert(1);
      opacity: 0.9;
    }

    .panel-left__body {
      position: relative;
      z-index: 1;
    }
    .panel-left__eyebrow {
      font-size: 11px;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      font-weight: 500;
      margin-bottom: 20px;
    }
    .panel-left__heading {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(32px, 3.2vw, 44px);
      font-weight: 400;
      color: #fff;
      line-height: 1.15;
      margin-bottom: 20px;
    }
    .panel-left__heading em {
      font-style: italic;
      color: rgba(196,149,106,0.9);
    }
    .panel-left__desc {
      font-size: 14px;
      line-height: 1.7;
      color: rgba(255,255,255,0.45);
      max-width: 320px;
    }

    .panel-left__footer {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .panel-left__dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--teal);
    }
    .panel-left__footer-text {
      font-size: 12px;
      color: rgba(255,255,255,0.25);
      letter-spacing: .04em;
    }

    /* ── Right panel ── */
    .panel-right {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 48px 40px;
      position: relative;
    }

    .login-box {
      width: 100%;
      max-width: 380px;
      animation: fadeUp .5s cubic-bezier(.16,1,.3,1) both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .login-box__header {
      margin-bottom: 36px;
    }
    .login-box__title {
      font-family: 'Instrument Serif', serif;
      font-size: 26px;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 6px;
    }
    .login-box__sub {
      font-size: 14px;
      color: var(--ink-soft);
    }

    .form-group {
      margin-bottom: 20px;
    }
    .form-group label {
      display: block;
      font-size: 12.5px;
      font-weight: 600;
      color: var(--ink-soft);
      letter-spacing: .04em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .form-group input {
      width: 100%;
      padding: 13px 16px;
      border: 1.5px solid var(--line);
      border-radius: 10px;
      font-size: 14.5px;
      font-family: 'DM Sans', sans-serif;
      color: var(--ink);
      background: #fff;
      transition: border-color .2s, box-shadow .2s;
      outline: none;
      -webkit-appearance: none;
    }
    .form-group input:focus {
      border-color: var(--teal);
      box-shadow: 0 0 0 3px rgba(46,132,123,0.1);
    }
    .form-group input::placeholder {
      color: #aabfbd;
    }

    .login-error {
      background: #fff5f5;
      border: 1px solid #fcc;
      border-radius: 8px;
      padding: 12px 14px;
      font-size: 13px;
      color: #c0392b;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .login-error::before {
      content: '!';
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: #fcc;
      color: #c0392b;
      font-size: 11px;
      font-weight: 700;
      flex-shrink: 0;
    }

    .btn-signin {
      width: 100%;
      padding: 14px;
      background: var(--teal-dk);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-size: 14.5px;
      font-weight: 600;
      font-family: 'DM Sans', sans-serif;
      cursor: pointer;
      margin-top: 8px;
      transition: background .2s, transform .15s, box-shadow .2s;
      letter-spacing: .01em;
    }
    .btn-signin:hover {
      background: var(--teal);
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(46,132,123,0.28);
    }
    .btn-signin:active {
      transform: translateY(0);
    }

    /* divider line */
    .login-divider {
      height: 1px;
      background: var(--line);
      margin: 28px 0;
    }
    .login-back {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-size: 13px;
      color: var(--ink-soft);
      text-decoration: none;
      transition: color .18s;
    }
    .login-back:hover { color: var(--teal); }
    .login-back svg { width: 14px; height: 14px; }

    @media (max-width: 680px) {
      .panel-left { display: none; }
      .panel-right { padding: 32px 24px; }
    }
  </style>
</head>
<body>

  <!-- LEFT PANEL -->
  <div class="panel-left">
    <svg class="panel-left__pattern" viewBox="0 0 600 800" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <defs>
        <pattern id="geo" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
          <polygon points="40,4 76,22 76,58 40,76 4,58 4,22" fill="none" stroke="#fff" stroke-width="1"/>
          <polygon points="40,18 62,29 62,51 40,62 18,51 18,29" fill="none" stroke="#fff" stroke-width="0.5"/>
          <circle cx="40" cy="40" r="4" fill="#fff" opacity="0.4"/>
        </pattern>
      </defs>
      <rect width="600" height="800" fill="url(#geo)"/>
    </svg>

    <div class="panel-left__logo">
      <img src="/images/logo-light.png" alt="Laha Space" />
    </div>

    <div class="panel-left__body">
      <p class="panel-left__eyebrow">Admin Portal</p>
      <h1 class="panel-left__heading">
        Manage your<br/>
        <em>platform.</em>
      </h1>
      <p class="panel-left__desc">
        Review applicants, manage teachers, moderate bookings and keep the community running smoothly.
      </p>
    </div>

    <div class="panel-left__footer">
      <div class="panel-left__dot"></div>
      <span class="panel-left__footer-text">Laha Space · Admin Access Only</span>
    </div>
  </div>

  <!-- RIGHT PANEL -->
  <div class="panel-right">
    <div class="login-box">
      <div class="login-box__header">
        <h2 class="login-box__title">Welcome back</h2>
        <p class="login-box__sub">Sign in to your admin account</p>
      </div>

      <% if (error) { %>
      <div class="login-error"><%= error %></div>
      <% } %>

      <form action="/admin/login" method="POST">
        <div class="form-group">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" autofocus required />
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="••••••••" required />
        </div>
        <button type="submit" class="btn-signin">Sign in →</button>
      </form>

      <div class="login-divider"></div>
      <a href="/" class="login-back">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Back to Laha Space
      </a>
    </div>
  </div>

</body>
</html>
