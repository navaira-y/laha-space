<%- include('partials/public-head', { title: 'Find a Teacher' }) %>

<section class="hero">
  <div class="hero__orb hero__orb--1"></div>
  <div class="hero__orb hero__orb--2"></div>
  <div class="hero__orb hero__orb--3"></div>

  <div class="container hero__inner">
    <div class="hero__content">
      <div class="hero__eyebrow" id="heroEyebrow">
        <span class="hero__eyebrow-line"></span>
        A space for her
        <span class="hero__eyebrow-line"></span>
      </div>
      <h1 class="hero__title" id="heroTitle">
        Learn Quran from a teacher
        <span class="hero__title-em">you can trust</span>
      </h1>
      <p class="hero__desc" id="heroDesc">
        Every teacher on Laha Space has been personally vetted by our team. You focus on learning. We handle the trust.
      </p>
      <div class="hero__actions" id="heroActions">
        <a href="#teachers" class="btn btn--primary btn--lg">Browse Teachers</a>
        <a href="/apply" class="btn btn--sand btn--lg">Teach with us</a>
      </div>
    </div>

    <div class="hero__visual" id="heroVisual">
      <div class="hero__ring hero__ring--outer"></div>
      <div class="hero__ring hero__ring--mid"></div>
      <div class="hero__ring hero__ring--inner"></div>
      <div class="hero__visual-core">
        <!-- Quran SVG -->
        <svg width="72" height="60" viewBox="0 0 72 60" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Left page -->
          <path d="M36 8 C36 8 20 6 6 10 C4 10.5 3 12 3 14 L3 52 C3 54 4.5 55.5 6.5 55 C20 51 36 53 36 53 L36 8Z" fill="#f0f8f7" stroke="#2F877D" stroke-width="1.5"/>
          <!-- Right page -->
          <path d="M36 8 C36 8 52 6 66 10 C68 10.5 69 12 69 14 L69 52 C69 54 67.5 55.5 65.5 55 C52 51 36 53 36 53 L36 8Z" fill="#f0f8f7" stroke="#2F877D" stroke-width="1.5"/>
          <!-- Spine -->
          <path d="M36 8 L36 53" stroke="#1A4D47" stroke-width="2" stroke-linecap="round"/>
          <!-- Left lines (text) -->
          <line x1="12" y1="20" x2="30" y2="18.5" stroke="#2F877D" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
          <line x1="12" y1="26" x2="30" y2="24.5" stroke="#2F877D" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
          <line x1="12" y1="32" x2="30" y2="30.5" stroke="#D4A574" stroke-width="1.2" stroke-linecap="round" opacity="0.7"/>
          <line x1="12" y1="38" x2="30" y2="36.5" stroke="#2F877D" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
          <line x1="12" y1="44" x2="30" y2="42.5" stroke="#2F877D" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
          <!-- Right lines (text) -->
          <line x1="42" y1="18.5" x2="60" y2="20" stroke="#2F877D" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
          <line x1="42" y1="24.5" x2="60" y2="26" stroke="#2F877D" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
          <line x1="42" y1="30.5" x2="60" y2="32" stroke="#D4A574" stroke-width="1.2" stroke-linecap="round" opacity="0.7"/>
          <line x1="42" y1="36.5" x2="60" y2="38" stroke="#2F877D" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
          <line x1="42" y1="42.5" x2="60" y2="44" stroke="#2F877D" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
          <!-- Decorative star on spine -->
          <circle cx="36" cy="30" r="3" fill="#D4A574"/>
        </svg>
        <span class="hero__arabic-sub">Laha Space</span>
      </div>
      <div class="hero__badge hero__badge--1" id="heroBadge1">
        <span class="hero__badge-num">7</span>
        <span class="hero__badge-label">Vetting Stages</span>
      </div>
      <div class="hero__badge hero__badge--2" id="heroBadge2">
        <span class="hero__badge-icon">✓</span>
        <span class="hero__badge-label">Vetted Teachers</span>
      </div>
    </div>
  </div>
</section>

<section class="trust-strip">
  <div class="container">
    <div class="trust-strip__inner">
      <div class="trust-strip__item" data-aos="fade-up">
        <div class="trust-strip__icon">◆</div>
        <div>
          <strong>Personally vetted</strong>
          <p>Every teacher reviewed by our team</p>
        </div>
      </div>
      <div class="trust-strip__sep"></div>
      <div class="trust-strip__item" data-aos="fade-up" data-aos-delay="100">
        <div class="trust-strip__icon">◆</div>
        <div>
          <strong>Seven stage process</strong>
          <p>No shortcuts, no exceptions</p>
        </div>
      </div>
      <div class="trust-strip__sep"></div>
      <div class="trust-strip__item" data-aos="fade-up" data-aos-delay="200">
        <div class="trust-strip__icon">◆</div>
        <div>
          <strong>Qualified teachers</strong>
          <p>Ijazah holders and certified educators</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="vetting" id="vetting">
  <div class="container">
    <div class="vetting__header" data-aos="fade-up">
      <div class="section-eyebrow">How we choose our teachers</div>
      <h2 class="section-title">Seven stages. No shortcuts.</h2>
      <p class="section-desc">Every teacher you see here has passed through our full vetting process. Here is exactly what that means.</p>
    </div>

    <div class="vetting__steps">
      <div class="vetting__step" data-aos="fade-up">
        <div class="vetting__step-num">01</div>
        <div class="vetting__step-body"><h4>Application</h4><p>The teacher submits a detailed application including their qualifications, ijazah and teaching experience.</p></div>
      </div>
      <div class="vetting__step" data-aos="fade-up" data-aos-delay="60">
        <div class="vetting__step-num">02</div>
        <div class="vetting__step-body"><h4>Initial Screening</h4><p>Our team reviews all submitted documents and qualifications before moving forward.</p></div>
      </div>
      <div class="vetting__step" data-aos="fade-up" data-aos-delay="120">
        <div class="vetting__step-num">03</div>
        <div class="vetting__step-body"><h4>Interview</h4><p>A one-on-one interview to understand the teacher's background, approach and values.</p></div>
      </div>
      <div class="vetting__step" data-aos="fade-up" data-aos-delay="180">
        <div class="vetting__step-num">04</div>
        <div class="vetting__step-body"><h4>Interview Review</h4><p>The team carefully evaluates all interview notes before proceeding to the practical stage.</p></div>
      </div>
      <div class="vetting__step" data-aos="fade-up" data-aos-delay="240">
        <div class="vetting__step-num">05</div>
        <div class="vetting__step-body"><h4>Teaching Test</h4><p>The teacher delivers a live teaching demonstration which is reviewed by our team.</p></div>
      </div>
      <div class="vetting__step" data-aos="fade-up" data-aos-delay="300">
        <div class="vetting__step-num">06</div>
        <div class="vetting__step-body"><h4>Training Program</h4><p>Accepted teachers complete our onboarding and training program before being listed.</p></div>
      </div>
      <!-- spacers to center 07 in middle column -->
      <div class="vetting__spacer"></div>
      <div class="vetting__step vetting__step--final" data-aos="fade-up" data-aos-delay="360">
        <div class="vetting__step-num">07</div>
        <div class="vetting__step-body"><h4>Fully Vetted</h4><p>Only now does the teacher appear on the platform. Every teacher you see here is here for a reason.</p></div>
      </div>
      <div class="vetting__spacer"></div>
    </div>
  </div>
</section>

<section class="teachers-section" id="teachers">
  <div class="container">
    <div class="teachers-section__header" data-aos="fade-up">
      <div class="section-eyebrow">Our teachers</div>
      <h2 class="section-title">Meet the community</h2>
      <p class="section-desc">Browse our vetted teachers and book a free discovery session with the one that feels right for you.</p>
    </div>
    <div class="teacher-filters" data-aos="fade-up" data-aos-delay="100">
      <button class="filter-btn filter-btn--active" data-category="all">All teachers</button>
      <button class="filter-btn" data-category="tajweed">Tajweed</button>
      <button class="filter-btn" data-category="memorization">Memorization</button>
      <button class="filter-btn" data-category="beginner">Beginner</button>
    </div>
    <div class="teacher-grid" id="teacherGrid">
      <div class="grid-loading">
        <div class="grid-loading__dot"></div>
        <div class="grid-loading__dot"></div>
        <div class="grid-loading__dot"></div>
      </div>
    </div>
  </div>
</section>

<section class="apply-cta" data-aos="fade-up">
  <div class="container">
    <div class="apply-cta__inner">
      <div class="apply-cta__content">
        <div class="section-eyebrow" style="color:var(--sand)">Are you a teacher?</div>
        <h2 class="apply-cta__title">Join our community of vetted teachers</h2>
        <p>If you hold an ijazah or have verified qualifications and are passionate about teaching Quran to women, we would love to hear from you.</p>
      </div>
      <a href="/apply" class="btn btn--sand btn--lg">Apply to teach</a>
    </div>
  </div>
</section>

<div class="modal-overlay" id="teacherModal" hidden>
  <div class="modal">
    <button class="modal__close" id="modalClose">&times;</button>
    <div class="modal__body" id="modalBody"></div>
  </div>
</div>

<div class="modal-overlay" id="bookingModal" hidden>
  <div class="modal modal--booking">
    <button class="modal__close" id="bookingModalClose">&times;</button>
    <div class="modal__body" id="bookingModalBody"></div>
  </div>
</div>

<%- include('partials/public-foot') %>
