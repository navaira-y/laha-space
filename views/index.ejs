<%- include('partials/public-head', { title: 'Find a Teacher' }) %>

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__tag">A space for her</div>
    <h1 class="hero__title">Learn Quran from a<br/>teacher you can trust</h1>
    <p class="hero__desc">Every teacher on Laha Space has been personally vetted by our team. You focus on learning — we handle the trust.</p>
    <a href="#teachers" class="btn btn--primary btn--lg">Browse Teachers</a>
  </div>
</section>

<section class="vetting">
  <div class="container">
    <div class="vetting__header">
      <div class="section-tag">How we choose our teachers</div>
      <h2 class="section-title">Seven stages. No shortcuts.</h2>
      <p class="section-desc">Every teacher you see here has passed through our full vetting process. Here is exactly what that means.</p>
    </div>
    <div class="vetting__steps">
      <div class="vetting__step">
        <div class="vetting__num">01</div>
        <div class="vetting__content">
          <h4>Application</h4>
          <p>The teacher submits a detailed application including their qualifications, ijazah, and teaching experience.</p>
        </div>
      </div>
      <div class="vetting__step">
        <div class="vetting__num">02</div>
        <div class="vetting__content">
          <h4>Initial Screening</h4>
          <p>Our team reviews all submitted documents and qualifications before moving forward.</p>
        </div>
      </div>
      <div class="vetting__step">
        <div class="vetting__num">03</div>
        <div class="vetting__content">
          <h4>Interview</h4>
          <p>A one-on-one interview to understand the teacher's background, approach, and values.</p>
        </div>
      </div>
      <div class="vetting__step">
        <div class="vetting__num">04</div>
        <div class="vetting__content">
          <h4>Interview Review</h4>
          <p>The team carefully evaluates all interview notes before proceeding to the practical stage.</p>
        </div>
      </div>
      <div class="vetting__step">
        <div class="vetting__num">05</div>
        <div class="vetting__content">
          <h4>Teaching Test</h4>
          <p>The teacher delivers a live teaching demonstration which is reviewed by our team.</p>
        </div>
      </div>
      <div class="vetting__step">
        <div class="vetting__num">06</div>
        <div class="vetting__content">
          <h4>Training Program</h4>
          <p>Accepted teachers complete our onboarding and training program before being listed.</p>
        </div>
      </div>
      <div class="vetting__step">
        <div class="vetting__num">07</div>
        <div class="vetting__content">
          <h4>Fully Vetted</h4>
          <p>Only now does the teacher appear on the platform. Every teacher you see here is here for a reason.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="teachers-section" id="teachers">
  <div class="container">
    <div class="teachers-section__header">
      <div class="section-tag">Our teachers</div>
      <h2 class="section-title">Meet the community</h2>
    </div>
    <div class="teacher-filters">
      <button class="filter-btn filter-btn--active" data-category="all">All</button>
      <button class="filter-btn" data-category="tajweed">Tajweed</button>
      <button class="filter-btn" data-category="memorization">Memorization</button>
      <button class="filter-btn" data-category="beginner">Beginner</button>
    </div>
    <div class="teacher-grid" id="teacherGrid">
      <div class="loading-state">Loading teachers...</div>
    </div>
  </div>
</section>

<!-- Teacher Detail Modal -->
<div class="modal-overlay" id="teacherModal" hidden>
  <div class="modal">
    <button class="modal__close" id="modalClose" aria-label="Close">&times;</button>
    <div class="modal__body" id="modalBody"></div>
  </div>
</div>

<!-- Booking Modal -->
<div class="modal-overlay" id="bookingModal" hidden>
  <div class="modal modal--booking">
    <button class="modal__close" id="bookingModalClose">&times;</button>
    <div class="modal__body" id="bookingModalBody"></div>
  </div>
</div>

<%- include('partials/public-foot') %>
