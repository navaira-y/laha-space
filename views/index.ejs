<%- include('partials/public-head', { title: 'Find a Teacher' }) %>

<section class="hero">
  <div class="hero__bg-img" aria-hidden="true"></div>
  <div class="hero__overlay" aria-hidden="true"></div>
  <div class="container hero__inner">

    <div class="hero__left">
      <div class="hero__eyebrow" id="heroEyebrow">
        <span class="hero__eyebrow-arabic">لها</span>
        <span class="hero__eyebrow-sep">·</span>
        <span>A space for her</span>
      </div>

      <h1 class="hero__title" id="heroTitle">
        Learn the Quran from a teacher
        <em>you can trust.</em>
      </h1>

      <p class="hero__desc" id="heroDesc">
        Every teacher on Laha Space passes through a seven-stage personal vetting process before her profile goes live. You focus on learning. We take care of the rest.
      </p>

      <div class="hero__actions" id="heroActions">
        <a href="#teachers" class="pill pill--solid">
          <span>Browse teachers</span>
          <span class="pill__arrow" aria-hidden="true">→</span>
        </a>
        <a href="/apply" class="pill pill--ghost">
          <span>Teach with us</span>
          <span class="pill__arrow" aria-hidden="true">↗</span>
        </a>
      </div>
    </div>


  </div>
</section>

<section class="marquee" aria-label="Trust signals">
  <div class="marquee__track">
    <span>Personally vetted teachers</span>
    <span class="msep">◇</span>
    <span>Ijazah holders</span>
    <span class="msep">◇</span>
    <span>Tajweed certified</span>
    <span class="msep">◇</span>
    <span>Women only platform</span>
    <span class="msep">◇</span>
    <span>Seven stage process</span>
    <span class="msep">◇</span>
