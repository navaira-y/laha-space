<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' · ' : '' %>Laha Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" href="/images/favicon.png" />
  <link rel="stylesheet" href="/css/style.css" />
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var btn = document.getElementById('adminHamburger');
      var sidebar = document.getElementById('adminSidebar');
      var overlay = document.getElementById('sidebarOverlay');
      if (!btn) return;
      function open() { sidebar.classList.add('sidebar--open'); overlay.classList.add('active'); }
      function close() { sidebar.classList.remove('sidebar--open'); overlay.classList.remove('active'); }
      btn.addEventListener('click', function() { sidebar.classList.contains('sidebar--open') ? close() : open(); });
      overlay.addEventListener('click', close);
    });
  </script>
</head>
<body class="admin-body">
  <div class="admin-layout">
    <!-- Mobile header (hidden on desktop with inline media query) -->
    <style>
      @media (min-width: 1025px) {
        .admin-mobile-header { display: none !important; }
        .admin-sidebar-overlay { display: none !important; }
      }
      .admin-mobile-logo {
        height: 32px !important;
        width: auto !important;
        max-width: 200px !important;
      }
      .admin-topbar {
        background: #1a2e2c !important;
        border-bottom: 1px solid rgba(255,255,255,0.07) !important;
      }
      .admin-topbar__title {
        font-size: 21px !important;
        font-weight: 600 !important;
        color: #fff !important;
      }
      @media (max-width: 1024px) {
        .sidebar__brand { display: none !important; }
      }
    </style>
    <header class="admin-mobile-header">
      <img src="/images/logo-light.png" alt="Laha Space" class="admin-mobile-logo" style="height:32px;width:auto;max-width:200px;" />
      <button class="admin-hamburger" id="adminHamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </header>
    <div class="admin-sidebar-overlay" id="sidebarOverlay"></div>

    <aside class="sidebar" id="adminSidebar">
      <div class="sidebar__brand">
        <img src="/images/logo-light.png" alt="Laha Space" style="height:36px;width:auto;max-width:100%;display:block;" />
      </div>
      <nav class="sidebar__nav">
        <a href="/admin" class="sidebar__link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'sidebar__link--active' : '' %>">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          Dashboard
        </a>
        <a href="/admin/applicants" class="sidebar__link <%= typeof activePage !== 'undefined' && activePage === 'applicants' ? 'sidebar__link--active' : '' %>">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Applicants
        </a>
        <a href="/admin/teachers" class="sidebar__link <%= typeof activePage !== 'undefined' && activePage === 'teachers' ? 'sidebar__link--active' : '' %>">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Teachers
        </a>
        <a href="/admin/bookings" class="sidebar__link <%= typeof activePage !== 'undefined' && activePage === 'bookings' ? 'sidebar__link--active' : '' %>">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Bookings
        </a>
        <a href="/admin/reviews" class="sidebar__link <%= typeof activePage !== 'undefined' && activePage === 'reviews' ? 'sidebar__link--active' : '' %>">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          Reviews
        </a>
        <a href="/admin/community" class="sidebar__link <%= typeof activePage !== 'undefined' && activePage === 'community' ? 'sidebar__link--active' : '' %>">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Community
        </a>
      </nav>
      <a href="/admin/logout" class="sidebar__logout">Sign out</a>
    </aside>
    <main class="admin-main">
      <div class="admin-topbar"><span class="admin-topbar__title"><%= typeof title !== 'undefined' ? title : 'Admin' %></span></div>
