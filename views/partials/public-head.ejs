<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' · ' : '' %>Laha Space</title>
  <meta name="description" content="Laha Space — vetted Quran teachers for women." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&family=Noto+Naskh+Arabic:wght@400;700&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="grain" aria-hidden="true"></div>

  <header class="nav">
    <div class="container nav__inner">
      <a href="/" class="nav__logo" aria-label="لها Space">
<span class="nav__logo-text">
          <span class="nav__logo-laha">لها</span><span class="nav__logo-space">Space</span>
        </span>
      </a>

      <nav class="nav__menu" aria-label="Primary">
        <a href="/#teachers" class="nav__link">Teachers</a>
        <a href="/#vetting" class="nav__link">How we vet</a>
        <a href="/#story" class="nav__link">Our story</a>
      </nav>

      <div class="nav__cta">
        <a href="/apply" class="pill pill--dark">
          <span>Join us</span>
          <span class="pill__arrow" aria-hidden="true">↗</span>
        </a>
      </div>

      <button class="nav__burger" id="navBurger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>

    <div class="nav__drawer" id="navDrawer" hidden>
      <a href="/#teachers" class="nav__drawer-link">Teachers</a>
      <a href="/#vetting" class="nav__drawer-link">How we vet</a>
      <a href="/#story" class="nav__drawer-link">Our story</a>
      <a href="/apply" class="nav__drawer-link nav__drawer-link--cta">Join us ↗</a>
    </div>
  </header>
