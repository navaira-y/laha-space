<%- include('partials/public-head', { title: 'Apply to Teach' }) %>

<section class="page-hero">
  <div class="container">
    <div class="section-tag">Teach with Laha Space</div>
    <h1 class="page-hero__title">Apply to become a teacher</h1>
    <p class="page-hero__desc">We vet every teacher personally. If you are accepted, you will be listed on the platform and connected with students looking for exactly what you offer.</p>
  </div>
</section>

<section class="form-section">
  <div class="container container--narrow">

    <% if (success) { %>
    <div class="alert alert--success">
      <strong>Application received.</strong> We have noted your details and will be in touch. JazakAllahu khairan.
    </div>
    <% } else { %>

    <% if (error) { %>
    <div class="alert alert--error"><%= error %></div>
    <% } %>

    <form class="form" action="/apply" method="POST" enctype="multipart/form-data" id="applyForm">
      <div class="form__section">
        <h3 class="form__section-title">Your details</h3>
        <div class="form__row">
          <div class="form__group">
            <label class="form__label">Full name <span class="required">*</span></label>
            <input class="form__input" type="text" name="name" required />
          </div>
          <div class="form__group">
            <label class="form__label">Email address <span class="required">*</span></label>
            <input class="form__input" type="email" name="email" required />
          </div>
        </div>
        <div class="form__row">
          <div class="form__group">
            <label class="form__label">Phone / WhatsApp <span class="required">*</span></label>
            <input class="form__input" type="text" name="phone" required />
          </div>
          <div class="form__group">
            <label class="form__label">Country and city <span class="required">*</span></label>
            <input class="form__input" type="text" name="country_city" placeholder="e.g. Pakistan, Lahore" required />
          </div>
        </div>
        <div class="form__group">
          <label class="form__label">Photo <span class="form__hint">(optional now, required before going live)</span></label>
          <input class="form__input form__input--file" type="file" name="photo" id="photoInput"
            accept=".jpg,.jpeg,.png,.webp" />
          <p class="form__file-hint">Accepted formats: JPG, JPEG, PNG, WEBP</p>
          <p class="form__file-error" id="photoError"></p>
        </div>
      </div>

      <div class="form__section">
        <h3 class="form__section-title">Teaching background</h3>
        <div class="form__group">
          <label class="form__label">Qualifications and ijazah <span class="required">*</span></label>
          <textarea class="form__input form__textarea" name="qualifications" rows="4" placeholder="Describe your qualifications, certifications, and any ijazah you hold." required></textarea>
        </div>
        <div class="form__group">
          <label class="form__label">Teaching experience <span class="required">*</span></label>
          <textarea class="form__input form__textarea" name="experience" rows="4" placeholder="How long have you been teaching? Who have you taught? What experience do you have?" required></textarea>
        </div>
      </div>

      <div class="form__section">
        <h3 class="form__section-title">What you teach</h3>
        <div class="form__group">
          <label class="form__label">Areas of teaching <span class="required">*</span></label>
          <div class="checkbox-group">
            <label class="checkbox-label">
              <input type="checkbox" name="categories" value="tajweed" />
              <span>Tajweed</span>
            </label>
            <label class="checkbox-label">
              <input type="checkbox" name="categories" value="memorization" />
              <span>Memorization (Hifz)</span>
            </label>
            <label class="checkbox-label">
              <input type="checkbox" name="categories" value="beginner" />
              <span>Beginner (Qaida / Noorani)</span>
            </label>
          </div>
        </div>
        <div class="form__group">
          <label class="form__label">Languages you teach in <span class="required">*</span></label>
          <div class="checkbox-group">
            <label class="checkbox-label"><input type="checkbox" name="languages" value="Arabic" /><span>Arabic</span></label>
            <label class="checkbox-label"><input type="checkbox" name="languages" value="English" /><span>English</span></label>
            <label class="checkbox-label"><input type="checkbox" name="languages" value="Urdu" /><span>Urdu</span></label>
            <label class="checkbox-label"><input type="checkbox" name="languages" value="French" /><span>French</span></label>
            <label class="checkbox-label"><input type="checkbox" name="languages" value="Other" /><span>Other</span></label>
          </div>
        </div>
        <div class="form__group">
          <label class="form__label">General availability</label>
          <input class="form__input" type="text" name="availability_text" placeholder="e.g. Weekday mornings, Weekends (Gulf time)" />
        </div>
      </div>

      <div class="form__section">
        <h3 class="form__section-title">Supporting documents</h3>
        <div class="form__group">
          <label class="form__label">Upload documents <span class="form__hint">(certificates, ijazah scan, etc. — up to 10 files)</span></label>
          <input class="form__input form__input--file" type="file" name="documents" id="docsInput"
            accept=".pdf,.jpg,.jpeg,.png,.docx" multiple />
          <p class="form__file-hint">Accepted formats: PDF, JPG, JPEG, PNG, DOCX</p>
          <p class="form__file-error" id="docsError"></p>
        </div>
        <div class="form__group">
          <label class="form__label">Anything else you'd like us to know?</label>
          <textarea class="form__input form__textarea" name="extra_info" rows="3"></textarea>
        </div>
      </div>

      <p class="form__privacy">Your information is only accessible to the Laha Space team and will not be shared publicly without your permission.</p>

      <button type="submit" class="btn btn--primary btn--lg">Submit application</button>
    </form>

    <% } %>
  </div>
</section>

<script>
const ALLOWED_PHOTO = ['.jpg', '.jpeg', '.png', '.webp'];
const ALLOWED_DOCS  = ['.pdf', '.jpg', '.jpeg', '.png', '.docx'];

function getExt(filename) {
  return filename.slice(filename.lastIndexOf('.')).toLowerCase();
}

document.getElementById('photoInput').addEventListener('change', function() {
  const error = document.getElementById('photoError');
  const file = this.files[0];
  if (!file) { error.textContent = ''; return; }
  if (!ALLOWED_PHOTO.includes(getExt(file.name))) {
    error.textContent = 'This file type is not allowed. Please upload a JPG, JPEG, PNG, or WEBP image.';
    this.value = '';
  } else {
    error.textContent = '';
  }
});

document.getElementById('docsInput').addEventListener('change', function() {
  const error = document.getElementById('docsError');
  const files = Array.from(this.files);
  const bad = files.filter(f => !ALLOWED_DOCS.includes(getExt(f.name)));
  if (bad.length) {
    error.textContent = 'Some files were not allowed and removed: ' + bad.map(f => f.name).join(', ') + '. Only PDF, JPG, JPEG, PNG, DOCX are accepted.';
    this.value = '';
  } else {
    error.textContent = '';
  }
});

document.getElementById('applyForm').addEventListener('submit', function(e) {
  const photoInput = document.getElementById('photoInput');
  const docsInput  = document.getElementById('docsInput');
  let blocked = false;

  if (photoInput.files[0] && !ALLOWED_PHOTO.includes(getExt(photoInput.files[0].name))) {
    document.getElementById('photoError').textContent = 'Please remove the invalid photo file before submitting.';
    blocked = true;
  }

  const badDoc = Array.from(docsInput.files).find(f => !ALLOWED_DOCS.includes(getExt(f.name)));
  if (badDoc) {
    document.getElementById('docsError').textContent = 'Please remove invalid document files before submitting.';
    blocked = true;
  }

  if (blocked) e.preventDefault();
});
</script>

<style>
.form__file-hint { font-size: 13px; color: var(--text-muted, #888); margin-top: 4px; }
.form__file-error { font-size: 13px; color: #c0392b; margin-top: 4px; min-height: 18px; }
</style>

<%- include('partials/public-foot') %>
