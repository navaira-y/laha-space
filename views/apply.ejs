<%- include('partials/public-head', { title: 'Apply to Teach' }) %>

<section class="page-hero">
  <div class="container page-hero__inner">
    <div class="section-num">→</div>
    <div>
      <span class="section-eyebrow">Teach with Laha Space</span>
      <h1 class="page-hero__title">
        Apply to become<br/>
        <em>a teacher.</em>
      </h1>
      <p class="page-hero__desc">
        Every teacher is personally reviewed by our team. If your application is accepted, your profile will be listed on
        Laha Space and shown to students seeking your area of teaching.
      </p>
    </div>
  </div>
</section>

<section class="form-section">
  <div class="container container--narrow">

    <% if (success) { %>
    <div class="alert alert--success">
      <strong>Application received.</strong> We have noted your details and will be in touch soon, in shaa Allah. JazakAllahu khairan.
    </div>
    <% } else { %>

    <% if (error) { %>
    <div class="alert alert--error"><%= error %></div>
    <% } %>

    <form class="form" action="/apply" method="POST" enctype="multipart/form-data" id="applyForm">

      <div class="form__section">
        <div class="form__section-head">
          <span class="form__section-num">01</span>
          <h3 class="form__section-title">Your details</h3>
        </div>
        <div class="form__row">
          <div class="form__group">
            <label class="form__label">Full name <span class="required">*</span></label>
            <input class="form__input" type="text" name="name" required />
          </div>
          <div class="form__group">
            <label class="form__label">Email address <span class="required">*</span></label>
            <input class="form__input" type="email" name="email" required />
          </div>
        </div>
        <div class="form__row">
          <div class="form__group">
            <label class="form__label">Phone / WhatsApp <span class="required">*</span></label>
            <div style="display:flex;gap:8px;">
              <select class="form__input" name="phone_code" id="applyPhoneCode" style="max-width:140px;flex-shrink:0">
                <option value="+971">🇦🇪 +971</option>
                <option value="+966">🇸🇦 +966</option>
                <option value="+965">🇰🇼 +965</option>
                <option value="+974">🇶🇦 +974</option>
                <option value="+973">🇧🇭 +973</option>
                <option value="+968">🇴🇲 +968</option>
                <option value="+92">🇵🇰 +92</option>
                <option value="+91">🇮🇳 +91</option>
                <option value="+880">🇧🇩 +880</option>
                <option value="+44">🇬🇧 +44</option>
                <option value="+1">🇺🇸 +1</option>
                <option value="+33">🇫🇷 +33</option>
                <option value="+49">🇩🇪 +49</option>
                <option value="+20">🇪🇬 +20</option>
                <option value="+212">🇲🇦 +212</option>
                <option value="+234">🇳🇬 +234</option>
                <option value="+60">🇲🇾 +60</option>
                <option value="+62">🇮🇩 +62</option>
                <option value="+65">🇸🇬 +65</option>
                <option value="+61">🇦🇺 +61</option>
                <option value="+other">Other</option>
              </select>
              <input class="form__input" type="tel" name="phone" id="applyPhone" placeholder="5xxxxxxxx" required style="flex:1" />
            </div>
          </div>
          <div class="form__group">
            <label class="form__label">Country and city <span class="required">*</span></label>
            <input class="form__input" type="text" name="country_city" placeholder="e.g. UAE, Dubai" required />
          </div>
        </div>
        <div class="form__group">
          <label class="form__label">Photo <span class="required">*</span></label>
          <input class="form__input form__input--file" type="file" name="photo" id="photoInput"
            accept=".jpg,.jpeg,.png,.webp" required />
          <p class="form__file-hint">Accepted formats: JPG, JPEG, PNG, WEBP</p>
          <p class="form__file-hint">If you wear niqab, please upload your photo with niqab.</p>
          <p class="form__file-error" id="photoError"></p>
        </div>
      </div>

      <div class="form__section">
        <div class="form__section-head">
          <span class="form__section-num">02</span>
          <h3 class="form__section-title">Teaching background</h3>
        </div>
        <div class="form__group">
          <label class="form__label">Qualifications and ijazah <span class="required">*</span></label>
          <textarea class="form__input form__textarea" name="qualifications" rows="4" placeholder="Describe your qualifications, certifications, and any ijazah you hold." required></textarea>
        </div>
        <div class="form__group">
          <label class="form__label">Teaching experience <span class="required">*</span></label>
          <textarea class="form__input form__textarea" name="experience" rows="4" placeholder="How long have you been teaching? Who have you taught? What experience do you have?" required></textarea>
        </div>
      </div>

      <div class="form__section">
        <div class="form__section-head">
          <span class="form__section-num">03</span>
          <h3 class="form__section-title">What you teach</h3>
        </div>
        <div class="form__group">
          <label class="form__label">Areas of teaching <span class="required">*</span></label>
          <div class="checkbox-group">
            <label class="checkbox-label">
              <input type="checkbox" name="categories" value="tajweed" />
              <span>Tajweed</span>
            </label>
            <label class="checkbox-label">
              <input type="checkbox" name="categories" value="memorization" />
              <span>Memorization (Hifz)</span>
            </label>
            <label class="checkbox-label">
              <input type="checkbox" name="categories" value="beginner" />
              <span>Beginner (Qaida / Noorani)</span>
            </label>
          </div>
        </div>
        <div class="form__group">
          <label class="form__label">Languages you teach in <span class="required">*</span></label>
          <div class="checkbox-group">
            <label class="checkbox-label"><input type="checkbox" name="languages" value="Arabic" /><span>Arabic</span></label>
            <label class="checkbox-label"><input type="checkbox" name="languages" value="English" /><span>English</span></label>
            <label class="checkbox-label"><input type="checkbox" name="languages" value="Urdu" /><span>Urdu</span></label>
            <label class="checkbox-label"><input type="checkbox" name="languages" value="French" /><span>French</span></label>
            <label class="checkbox-label"><input type="checkbox" name="languages" value="Other" id="otherLangCheck" /><span>Other</span></label>
          </div>
          <div id="otherLangBox" style="display:none;margin-top:12px;">
            <input class="form__input" type="text" name="languages_other" id="otherLangInput" placeholder="Please specify your language" />
          </div>
          <div style="display:none">
          </div>
        </div>
        <div class="form__group">
          <label class="form__label">Availability for student sessions <span class="required">*</span></label>
          <p class="form__file-hint" style="margin-bottom:14px;">Add the days and times you are available. You can add multiple windows.</p>
          <div id="availRows">
            <div class="avail-row">
              <select class="form__input avail-day-select">
                <option value="">— Day —</option>
                <option value="0">Sunday</option>
                <option value="1">Monday</option>
                <option value="2">Tuesday</option>
                <option value="3">Wednesday</option>
                <option value="4">Thursday</option>
                <option value="5">Friday</option>
                <option value="6">Saturday</option>
              </select>
              <input class="form__input avail-start-time" type="time" />
              <span class="avail-sep">to</span>
              <input class="form__input avail-end-time" type="time" />
              <button type="button" class="btn btn--danger btn--sm remove-avail-row">✕</button>
            </div>
          </div>
          <button type="button" class="btn btn--outline btn--sm" id="addAvailRow" style="margin-top:10px;">+ Add time window</button>
          <p class="form__file-error" id="availabilityError"></p>
          <input type="hidden" name="availability_text" id="availabilityText" />
        </div>
        <div class="form__group">
          <label class="form__label">Your time zone <span class="required">*</span></label>
          <select class="form__input" name="timezone" id="timezoneSelect" required>
            <option value="">Select your time zone</option>
            <optgroup label="Middle East">
              <option value="Asia/Dubai">UAE / Dubai (GST, UTC+4)</option>
              <option value="Asia/Riyadh">Saudi Arabia / Riyadh (AST, UTC+3)</option>
              <option value="Asia/Kuwait">Kuwait (AST, UTC+3)</option>
              <option value="Asia/Qatar">Qatar / Doha (AST, UTC+3)</option>
              <option value="Asia/Bahrain">Bahrain (AST, UTC+3)</option>
              <option value="Asia/Muscat">Oman / Muscat (GST, UTC+4)</option>
            </optgroup>
            <optgroup label="South Asia">
              <option value="Asia/Karachi">Pakistan / Karachi (PKT, UTC+5)</option>
              <option value="Asia/Kolkata">India (IST, UTC+5:30)</option>
              <option value="Asia/Dhaka">Bangladesh (BST, UTC+6)</option>
            </optgroup>
            <optgroup label="Southeast Asia">
              <option value="Asia/Jakarta">Indonesia / Jakarta (WIB, UTC+7)</option>
              <option value="Asia/Kuala_Lumpur">Malaysia (MYT, UTC+8)</option>
              <option value="Asia/Singapore">Singapore (SGT, UTC+8)</option>
            </optgroup>
            <optgroup label="Africa">
              <option value="Africa/Cairo">Egypt / Cairo (EET, UTC+2)</option>
              <option value="Africa/Casablanca">Morocco / Casablanca (WET, UTC+0/+1)</option>
              <option value="Africa/Tunis">Tunisia (CET, UTC+1)</option>
              <option value="Africa/Algiers">Algeria (CET, UTC+1)</option>
              <option value="Africa/Lagos">Nigeria / Lagos (WAT, UTC+1)</option>
              <option value="Africa/Nairobi">Kenya / Nairobi (EAT, UTC+3)</option>
            </optgroup>
            <optgroup label="Europe">
              <option value="Europe/London">UK / London (GMT/BST)</option>
              <option value="Europe/Paris">France / Paris (CET, UTC+1/+2)</option>
              <option value="Europe/Berlin">Germany / Berlin (CET, UTC+1/+2)</option>
              <option value="Europe/Amsterdam">Netherlands (CET, UTC+1/+2)</option>
              <option value="Europe/Stockholm">Sweden (CET, UTC+1/+2)</option>
            </optgroup>
            <optgroup label="North America">
              <option value="America/New_York">US Eastern (EST/EDT)</option>
              <option value="America/Chicago">US Central (CST/CDT)</option>
              <option value="America/Denver">US Mountain (MST/MDT)</option>
              <option value="America/Los_Angeles">US Pacific (PST/PDT)</option>
              <option value="America/Toronto">Canada / Toronto (EST/EDT)</option>
              <option value="America/Vancouver">Canada / Vancouver (PST/PDT)</option>
            </optgroup>
            <optgroup label="Other">
              <option value="Australia/Sydney">Australia / Sydney (AEST, UTC+10/+11)</option>
              <option value="Pacific/Auckland">New Zealand (NZST, UTC+12/+13)</option>
            </optgroup>
          </select>
          <p class="form__file-hint">Students will see your time zone when booking. Select the one that matches where you teach from.</p>
        </div>
        <div style="display:none">
        </div>
      </div>

      <div class="form__section">
        <div class="form__section-head">
          <span class="form__section-num">04</span>
          <h3 class="form__section-title">Supporting documents</h3>
        </div>
        <div class="form__group">
          <label class="form__label">Upload documents <span class="form__hint">(certificates, ijazah scan, etc. — maximum 10 files)</span></label>
          <input class="form__input form__input--file" type="file" name="documents" id="docsInput"
            accept=".pdf,.jpg,.jpeg,.png,.docx" multiple />
          <p class="form__file-hint">Accepted formats: PDF, JPG, JPEG, PNG, DOCX</p>
          <p class="form__file-error" id="docsError"></p>
        </div>
        <div class="form__group">
          <label class="form__label">Anything else you'd like us to know?</label>
          <textarea class="form__input form__textarea" name="extra_info" rows="3"></textarea>
        </div>
      </div>

      <p class="form__privacy">
        Your information is only accessible to the Laha Space team and will not be shared publicly without your permission.
      </p>

      <button type="submit" class="pill pill--solid pill--lg pill--full">
        <span>Submit application</span>
        <span class="pill__arrow" aria-hidden="true">→</span>
      </button>
    </form>

    <% } %>
  </div>
</section>

<script>
const ALLOWED_PHOTO = ['.jpg', '.jpeg', '.png', '.webp'];
const ALLOWED_DOCS  = ['.pdf', '.jpg', '.jpeg', '.png', '.docx'];
const DAY_ORDER = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];

function getExt(filename) {
  return filename.slice(filename.lastIndexOf('.')).toLowerCase();
}

// ─── Availability rows ──────────────────────────────────────
const DAY_NAMES = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

function buildAvailRow() {
  const div = document.createElement('div');
  div.className = 'avail-row';
  div.innerHTML = `
    <select class="form__input avail-day-select">
      <option value="">— Day —</option>
      ${DAY_NAMES.map((d,i) => `<option value="${i}">${d}</option>`).join('')}
    </select>
    <input class="form__input avail-start-time" type="time" />
    <span class="avail-sep">to</span>
    <input class="form__input avail-end-time" type="time" />
    <button type="button" class="btn btn--danger btn--sm remove-avail-row">✕</button>
  `;
  return div;
}

document.getElementById('addAvailRow').addEventListener('click', () => {
  document.getElementById('availRows').appendChild(buildAvailRow());
});

document.getElementById('availRows').addEventListener('click', e => {
  if (e.target.classList.contains('remove-avail-row')) {
    const rows = document.querySelectorAll('#availRows .avail-row');
    if (rows.length > 1) e.target.closest('.avail-row').remove();
  }
});

function getAvailData() {
  const rows = document.querySelectorAll('#availRows .avail-row');
  const data = [];
  for (const row of rows) {
    const day   = row.querySelector('.avail-day-select').value;
    const start = row.querySelector('.avail-start-time').value;
    const end   = row.querySelector('.avail-end-time').value;
    if (day !== '' && start && end) {
      if (start >= end) continue; // skip invalid ranges silently
      data.push({ day: parseInt(day), start, end });
    }
  }
  return data;
}

document.getElementById('photoInput').addEventListener('change', function() {
  const error = document.getElementById('photoError');
  const file = this.files[0];
  if (!file) { error.textContent = ''; return; }
  if (!ALLOWED_PHOTO.includes(getExt(file.name))) {
    error.textContent = 'This file type is not allowed. Please upload a JPG, JPEG, PNG, or WEBP image.';
    this.value = '';
  } else {
    error.textContent = '';
  }
});

document.getElementById('docsInput').addEventListener('change', function() {
  const error = document.getElementById('docsError');
  const files = Array.from(this.files);
  if (files.length > 10) {
    error.textContent = 'Maximum 10 files allowed. Please reduce your selection.';
    this.value = ''; return;
  }
  const bad = files.filter(f => !ALLOWED_DOCS.includes(getExt(f.name)));
  if (bad.length) {
    error.textContent = 'Some files are not allowed: ' + bad.map(f => f.name).join(', ') + '. Only PDF, JPG, JPEG, PNG, DOCX accepted.';
    this.value = '';
  } else {
    error.textContent = '';
  }
});

document.getElementById('applyForm').addEventListener('submit', function(e) {
  // Combine country code with phone number
  const phoneCodeEl = document.getElementById('applyPhoneCode');
  const phoneEl = document.getElementById('applyPhone');
  if (phoneCodeEl && phoneEl && phoneCodeEl.value !== '+other') {
    phoneEl.value = phoneCodeEl.value + ' ' + phoneEl.value.trim();
    phoneCodeEl.disabled = true;
  }
  const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
  const phoneRe = /^[0-9]{6,15}$/;
  const email = document.querySelector('input[name="email"]').value.trim();
  const phone = document.getElementById('applyPhone').value.trim();
  const name = document.querySelector('input[name="name"]').value.trim();

  if (name.length < 2) {
    e.preventDefault();
    alert('Please enter your full name.');
    return;
  }
  if (!emailRe.test(email)) {
    e.preventDefault();
    alert('Please enter a valid email address.');
    return;
  }
  if (!phoneRe.test(phone.replace(/\s/g, ''))) {
    e.preventDefault();
    alert('Please enter a valid phone number — digits only, no spaces or symbols.');
    return;
  }
  const photoInput = document.getElementById('photoInput');
  const docsInput  = document.getElementById('docsInput');
  let blocked = false;

  if (!photoInput.files[0]) {
    document.getElementById('photoError').textContent = 'A photo is required.';
    blocked = true;
  } else if (!ALLOWED_PHOTO.includes(getExt(photoInput.files[0].name))) {
    document.getElementById('photoError').textContent = 'Please remove the invalid photo file before submitting.';
    blocked = true;
  }

  const availData = getAvailData();
  if (availData.length === 0) {
    document.getElementById('availabilityError').textContent = 'Please add at least one availability window with a day and time range.';
    blocked = true;
  } else {
    document.getElementById('availabilityText').value = JSON.stringify(availData);
    document.getElementById('availabilityError').textContent = '';
  }

  if (docsInput.files.length > 10) {
    document.getElementById('docsError').textContent = 'You can upload a maximum of 10 documents. Please reduce your selection.';
    blocked = true;
  }

  const badDoc = Array.from(docsInput.files).find(f => !ALLOWED_DOCS.includes(getExt(f.name)));
  if (badDoc) {
    document.getElementById('docsError').textContent = 'Please remove invalid document files before submitting.';
    blocked = true;
  }

  if (blocked) e.preventDefault();
});
</script>

<script>
  document.getElementById('otherLangCheck').addEventListener('change', function() {
    var box = document.getElementById('otherLangBox');
    var input = document.getElementById('otherLangInput');
    box.style.display = this.checked ? 'block' : 'none';
    input.required = this.checked;
    if (!this.checked) input.value = '';
  });
</script>
<%- include('partials/public-foot') %>
