            <input class="form__input" type="tel" name="whatsapp" id="joinPhone" placeholder="5xxxxxxxx" required style="flex:1" />
          </div>
        </div>
      </div>

      <div class="form__section">
        <h3 class="form__section-title">03 &nbsp; A bit more</h3>
        <div class="form__group">
          <label class="form__label">What are you looking for? <span class="required">*</span></label>
          <textarea class="form__input form__textarea" name="why_join" rows="3" placeholder="e.g. I want to learn Tajweed, looking for a supportive community of sisters, etc." required></textarea>
        </div>
        <div class="form__group">
          <label class="form__label">Is there anything you can contribute? <span class="form__hint">(optional)</span></label>
          <textarea class="form__input form__textarea" name="can_contribute" rows="3" placeholder="e.g. I can help with translation, graphic design, social media, etc."></textarea>
        </div>
      </div>

      <p class="form__privacy">Your information is only used to connect you with the community and will not be shared publicly.</p>

      <button type="submit" class="btn btn--primary btn--lg">Join Laha Space</button>
    </form>

    <% } %>
  </div>
</section>

<script>
document.getElementById('joinForm')?.addEventListener('submit', function(e) {
  const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
  const phoneRe = /^[0-9]{5,15}$/;
  const name = document.querySelector('input[name="name"]').value.trim();
  const email = document.querySelector('input[name="email"]').value.trim();
  const phone = document.getElementById('joinPhone').value.trim();

  if (name.length < 2) { e.preventDefault(); alert('Please enter your full name.'); return; }
  if (!emailRe.test(email)) { e.preventDefault(); alert('Please enter a valid email address.'); return; }
  if (!phoneRe.test(phone.replace(/\s/g, ''))) { e.preventDefault(); alert('Please enter a valid WhatsApp number, digits only.'); return; }

  var code = document.getElementById('joinPhoneCode');
  var ph = document.getElementById('joinPhone');
  if (code && ph) { ph.value = code.value + ' ' + ph.value.trim(); code.disabled = true; }
});
</script>

<%- include('partials/public-foot') %>
